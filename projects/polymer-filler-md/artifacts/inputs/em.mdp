; Energy minimization (L-OPLS)
define = -DLOPLS

integrator = steep
emtol = 1000.0
emstep = 0.01
nsteps = 50000

cutoff-scheme = Verlet
nstlist = 20
rlist = 1.2
vdwtype = cut-off
vdw-modifier = force-switch
rvdw-switch = 1.0
rvdw = 1.2
coulombtype = PME
rcoulomb = 1.2

pbc = xyz
constraints = h-bonds
constraint-algorithm = lincs
