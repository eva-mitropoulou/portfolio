&CONTROL
  calculation   = 'vc-relax',
  prefix        = 'a_berlinite_vc',
  outdir        = '/home/ubuntu/Computational-Chemistry/DFT/QEspresso/berlinite/tmp_vc',
  pseudo_dir    = '../01_pseudos_library',
  restart_mode  = 'restart',                    ! change to 'restart' when resuming
  disk_io       = 'medium',                          ! writes density & wavefunctions each SCF
  wf_collect    = .true.,                            ! store WFs in single files for restart
  tprnfor       = .true.,
  tstress       = .true.,
  verbosity     = 'high',
  nstep         = 100,                               ! max ionic+cell steps
  forc_conv_thr = 1.0d-3,                            
/
&SYSTEM
  ibrav         = 0,
  nat           = 18,
  ntyp          = 3,
  ecutwfc       = 80,
  ecutrho       = 640,
  occupations   = 'fixed',
  input_dft     = 'PBE',
/
&ELECTRONS
  conv_thr      = 1.0d-8,
  mixing_beta   = 0.3,
  diagonalization = 'david',
/
&IONS
  ion_dynamics  = 'bfgs',
/
&CELL
  cell_dynamics = 'bfgs',
  press         = 0.0d0,                             
  press_conv_thr = 0.5d0,
  cell_dofree   = 'all',
/
K_POINTS automatic
  4 4 3  0 0 0

